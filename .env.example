# ============================================================
# Monk ModeX — environment variables
# Copy to .env.local and fill in real values. .env.local is gitignored.
# ============================================================

# --------------------------------------------------------------
# Anthropic API — required for diagnosis + protocol generation
# Get your key at: https://console.anthropic.com/settings/keys
# --------------------------------------------------------------
ANTHROPIC_API_KEY=

# Optional override — defaults to claude-opus-4-7
# ANTHROPIC_MODEL=claude-opus-4-7

# --------------------------------------------------------------
# Supabase — required for data persistence
# Create a project at: https://supabase.com
# Run the migrations in supabase/migrations/ via the SQL editor.
# --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — find under Project Settings → API → service_role key
# NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------
# App
# --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Monk ModeX

# --------------------------------------------------------------
# (Future — added when payments + auth + emails are wired in)
# --------------------------------------------------------------
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# LEMON_SQUEEZY_FOUNDATION_VARIANT_ID=
# LEMON_SQUEEZY_OPERATOR_VARIANT_ID=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
